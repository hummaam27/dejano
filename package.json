{
  "name": "dejano",
  "version": "0.1.0",
  "description": "Daily AI content generator that refuses to repeat itself. Semantic dedup + subtopic rotation, pluggable into any stack.",
  "type": "module",
  "bin": {
    "dejano": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "generate": "tsx src/cli.ts generate",
    "list": "tsx src/cli.ts list",
    "web": "tsx src/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "hono": "^4.6.12",
    "openai": "^4.73.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["ai", "openai", "deduplication", "embeddings", "content-generation", "llm"],
  "license": "MIT"
}
